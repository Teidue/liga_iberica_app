# Copia este archivo como .env y completa los valores
# cp .env.example .env

# Base de datos (PostgreSQL local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=liga_user
DB_PASSWORD=liga123
DB_NAME=liga_iberica

# JWT
